    color: var(--accent-gold);
    transition:
      box-shadow 160ms ease,
      transform 160ms ease;
  }

  .icon-tile:hover {
    transform: translateY(-1px);
  }

  .process-card {
    position: relative;
    overflow: hidden;
    transition:
      border-color 160ms ease,
      transform 160ms ease;
  }

  .process-card::after {
    content: "";
    position: absolute;
    inset: auto 16px 0;
    height: 3px;
    border-radius: 9999px 9999px 0 0;
    background: var(--accent-red);
    opacity: 0;
    transform: translateY(3px);
    transition:
      opacity 160ms ease,
      transform 160ms ease;
  }

  .process-card:hover {
    border-color: rgba(201, 169, 97, 0.52);
    transform: translateY(-2px);
  }

  .process-card:hover::after {
    opacity: 1;
    transform: translateY(0);
  }

  .section-container {
    width: min(100%, 1280px);
    margin-inline: auto;
  }

  .content-measure {
    max-width: 720px;
  }

  .copy-measure {
    max-width: 560px;
  }

  .section-kicker {
    color: var(--accent-gold);
    font-size: 13px;
    font-weight: 700;
    line-height: 1.35;
    text-transform: uppercase;
  }

  .section-kicker::after {
    content: "";
    display: block;
    width: 32px;
    height: 2px;
    margin-top: 8px;
    border-radius: 9999px;
    background: var(--accent-red);
