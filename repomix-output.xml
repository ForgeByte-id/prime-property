  .field-input::placeholder {
    color: #a3a3a3;
  }

  .field-input:focus {
    border-color: var(--accent-gold);
    box-shadow: 0 0 0 3px rgba(201, 169, 97, 0.28);
  }

  .field-input:user-invalid {
    border-color: var(--accent-red);
    box-shadow: 0 0 0 3px rgba(179, 58, 58, 0.16);
  }

  .badge-success,
  .badge-gold {
    display: inline-flex;
    align-items: center;
    border-radius: 9999px;
    padding: 4px 8px;
    font-size: 12px;
    font-weight: 600;
    line-height: 1.25;
  }

  .badge-success {
    background: #e6f4ec;
    color: #2f855a;
  }

  .badge-gold {
    background: #f3e8c8;
    color: var(--prime-black);
  }

  .badge-red {
    display: inline-flex;
    align-items: center;
    border-radius: 9999px;
    background: rgba(179, 58, 58, 0.12);
    color: var(--accent-red);
    padding: 4px 8px;
    font-size: 12px;
    font-weight: 700;
    line-height: 1.25;
  }

  .sidebar-link {
    border-radius: 8px;
    padding: 10px 12px;
    color: #1a1a1a;
    font-weight: 600;
  }

  .sidebar-link:hover {
    background: #f5f5f5;
  }

  .glass-panel {
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.08);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.12);
    backdrop-filter: blur(16px);
  }

  .nav-link-animated {
    position: relative;
    transition:
      color 160ms ease,
      transform 160ms ease;
  }

  .nav-link-animated::after {
    content: "";
    position: absolute;
    right: 0;
    bottom: -10px;
    left: 0;
    height: 2px;
    border-radius: 9999px;
    background: linear-gradient(90deg, var(--accent-gold), var(--accent-red));
    opacity: 0;
    transform: scaleX(0.4);
    transform-origin: center;
    transition:
      opacity 180ms ease,
      transform 180ms ease;
  }

  .nav-link-animated:hover {
    color: var(--text-primary);
    transform: translateY(-1px);
  }

  .nav-link-animated:hover::after {
    opacity: 1;
    transform: scaleX(1);
  }

  .animated-cta svg {
    transition: transform 180ms ease;
  }

  .animated-cta:hover svg {
    transform: translateX(4px);
  }

  .brand-pill {
    box-shadow: inset 0 0 0 1px rgba(201, 169, 97, 0.12);
  }

  .portfolio-row {
    transition:
      border-color 160ms ease,
      background-color 160ms ease,
      transform 160ms ease;
  }

  .portfolio-row:hover {
    border-color: rgba(201, 169, 97, 0.52);
    background: rgba(201, 169, 97, 0.08);
    transform: translateX(4px);
  }

