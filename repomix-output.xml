      const parsed = BigInt(value);
      if (parsed <= 0n) {
        context.addIssue({ code: z.ZodIssueCode.custom, message: "Harga harus lebih dari 0" });
        return z.NEVER;
      }
      return parsed;
    } catch {
      context.addIssue({ code: z.ZodIssueCode.custom, message: "Harga harus berupa integer Rupiah" });
      return z.NEVER;
